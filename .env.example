# ─── BASE DE DATOS ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://tableflow:tableflow_dev@localhost:5432/tableflow
REDIS_URL=redis://localhost:6379

# ─── AUTENTICACIÓN ────────────────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REEMPLAZAR_CON_SECRET_ALEATORIO
JWT_REFRESH_SECRET=REEMPLAZAR_CON_OTRO_SECRET_ALEATORIO
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── APLICACIÓN ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# ─── STRIPE (Fase 3 - SaaS Billing) ──────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_BASIC_PRICE_ID=
STRIPE_PRO_PRICE_ID=

# ─── EMAIL (Fase 4 - Automatizaciones) ───────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@tableflow.app

# ─── WHATSAPP (Fase 4 - Notificaciones) ──────────────────────────────────────
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
